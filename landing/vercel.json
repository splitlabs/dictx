{
  "redirects": [
    {
      "source": "/buy",
      "destination": "https://buy.splitlabs.io",
      "statusCode": 307
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=600"
        }
      ]
    }
  ]
}
